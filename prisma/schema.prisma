// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// schema.prisma

model User {
  id String @id @default(cuid())

  clerkId String @unique

  email String @unique
  name String?

  role Role @default(CUSTOMER)

  company Company? @relation(fields: [companyId], references: [id])
  companyId String?
  referralCode      ReferralCode?
  storeCredits      StoreCredit[]
  onboardingProgress OnboardingProgress?
  addresses Address[]
  notifications  Notification[]
  activityFeed   ActivityEntry[]
  orders Order[]
   reviews   Review[]
  subscriptions Subscription[]
  equipmentItems EquipmentRegistryItem[]
  companyMemberships CompanyMember[] // ← add
  serviceTickets     ServiceTicket[] // ← add
  invoices           Invoice[] 

  createdAt DateTime @default(now())
}
enum Role {
  CUSTOMER
  ADMIN
}

model Company {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  members CompanyMember[]
  addresses Address[]
  createdAt DateTime @default(now())
}

model Address {
  id        String   @id @default(cuid())

  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  orders    Order[]  // 👈 ADD THIS (inverse relation)

  line1     String
  line2     String?
  city      String
  state     String
  zip       String
  country   String   @default("US")
}

model Product {
  id              String        @id @default(cuid())
  category        ProductCategory
  name            String
  slug            String        @unique
  description     String
  priceCents      Int
  depositPercent  Int?
  leadTimeDays    Int?
  machineType   String?   // "espresso" | "grinder" | "batch-brew" | "accessories"
  packageSize   String?   // "4oz" | "8oz" | "12oz" | "16oz" | "20oz" | "24oz"
  material      String?   // "paper" | "compostable" | "plastic" | "PLA"
  caseQty       Int?      // units per case
  tags          String[]  // flexible search tags
  shortDesc     String?   // one-liner for search results
  stockQty      Int?     // null = unlimited/not tracked, 0 = out of stock
  lowStockThreshold Int? @default(10)
  reviews   Review[]

  certification   Certification? @relation(fields: [certificationId], references: [id])
  certificationId String?

  isSubscribable  Boolean @default(false)
  active          Boolean @default(true)
  images          String[]
  stripePriceId   String?   // Stripe recurring Price ID — subscriptions only
  createdAt       DateTime @default(now())

  // 👇 ADD THESE INVERSE RELATIONS
  orderItems      OrderItem[]
  subscriptions   Subscription[]
  equipmentItems  EquipmentRegistryItem[]
  productionBatches ProductionBatch[]
}



enum ProductCategory {
  EQUIPMENT
  PACKAGING
}

model Certification {
  id            String   @id @default(cuid())
  type          String
  listingNumber String
  documentUrl   String
  verifiedAt    DateTime?
  expiresAt     DateTime?

  createdAt     DateTime @default(now())

  products      Product[]
}

model Order {
  id              String       @id @default(cuid())
  user            User         @relation(fields: [userId], references: [id])
  userId          String

  status          OrderStatus  @default(PENDING_DEPOSIT)

  items           OrderItem[]
  invoice Invoice? // ← add
  depositPaidAt   DateTime?
  balancePaidAt   DateTime?

  stripeDepositPaymentIntentId String?
  stripeBalancePaymentIntentId String?

  shippingAddress Address? @relation(fields: [addressId], references: [id])
  addressId       String?

  estimatedShipDate DateTime?
  shippedAt       DateTime?

  createdAt       DateTime @default(now())

  // 👇 ADD THIS
  equipmentRegistryItems EquipmentRegistryItem[]
}

enum OrderStatus {
  PENDING
  PENDING_DEPOSIT     // equipment: waiting on deposit payment
  AWAITING_BALANCE    // equipment: deposit paid, sourcing/building, balance not yet due
  PAID                // packaging: paid in full, or equipment: balance paid
  IN_PRODUCTION        // equipment: factory order placed
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  PENDING_DEPOSIT
  AWAITING_BALANCE
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id          String   @id @default(cuid())

  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String

  product     Product  @relation(fields: [productId], references: [id])
  productId   String

  quantity       Int
  unitPriceCents Int

  // Equipment-specific per-item tracking
  // Packaging orders leave these null
  depositPercent Int?
  itemStatus     OrderItemStatus @default(PENDING_DEPOSIT)
  depositPaidAt  DateTime?
  balancePaidAt  DateTime?
  stripeDepositPaymentIntentId String?
  stripeBalancePaymentIntentId String?
  estimatedShipDate            DateTime?
  shippedAt                    DateTime?
}

model Subscription {
  id                    String   @id @default(cuid())

  user                  User     @relation(fields: [userId], references: [id])
  userId                String

  product               Product  @relation(fields: [productId], references: [id])
  productId             String

  stripeSubscriptionId  String   @unique
  status                String
  intervalDays          Int

  createdAt             DateTime @default(now())
}

model EquipmentRegistryItem {
  id            String   @id @default(cuid())

  user          User     @relation(fields: [userId], references: [id])
  userId        String

  product       Product  @relation(fields: [productId], references: [id])
  productId     String

  order         Order?   @relation(fields: [orderId], references: [id])
  orderId       String?
  serviceLogs    ServiceLog[]    // ← add
  serviceTickets ServiceTicket[] // ← add

  installedAt   DateTime?
  warrantyEndsAt DateTime?
  customName    String?   // stores declared name when not purchased from R&R
  customBrand   String?   // stores declared brand
}

model ProductionBatch {
  id          String   @id @default(cuid())
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  quantity    Int
  status      String
  eta         DateTime?
  createdAt   DateTime @default(now())  // ← add this
}

model Review {
  id        String   @id @default(cuid())

  product   Product  @relation(fields: [productId], references: [id])
  productId String

  user      User     @relation(fields: [userId], references: [id])
  userId    String

  rating    Int      // 1–5
  title     String?
  body      String

  // Only customers who actually ordered can review
  verified  Boolean  @default(false)

  createdAt DateTime @default(now())

  @@unique([productId, userId]) // one review per product per user
}


enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  CONVERTED
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  message   String
  interest  String?    // "equipment" | "packaging" | "both" | "custom"
  productId String?    // if from a specific product page quote button
  status    LeadStatus @default(NEW)
  notes     String?    // admin internal notes
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String
  company     String
  location    String?
  quote       String
  logoUrl     String?
  avatarUrl   String?
  rating      Int      @default(5)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

enum CompanyRole {
  OWNER
  MANAGER
  VIEWER
}

model CompanyMember {
  id        String      @id @default(cuid())
  company   Company     @relation(fields: [companyId], references: [id])
  companyId String
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  role      CompanyRole @default(MANAGER)
  location  String?     // which physical location this person manages
  createdAt DateTime    @default(now())

  @@unique([companyId, userId])
}

model ServiceLog {
  id            String                @id @default(cuid())
  equipment     EquipmentRegistryItem @relation(fields: [equipmentId], references: [id])
  equipmentId   String
  servicedAt    DateTime
  servicedBy    String                // technician name or company
  description   String                // what was done
  cost          Int?                  // in cents, optional
  nextServiceDue DateTime?
  createdAt     DateTime              @default(now())
}

model ServiceTicket {
  id          String   @id @default(cuid())
  equipment   EquipmentRegistryItem @relation(fields: [equipmentId], references: [id])
  equipmentId String
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  issue       String
  status      String   @default("open") // open | in_progress | resolved | closed
  notes       String?  // admin notes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String   @unique
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  pdfUrl      String?  // Uploadthing URL once generated
  invoiceNum  String   @unique // RR-2026-0001
  status      String   @default("draft") // draft | issued | paid
  issuedAt    DateTime @default(now())
  totalCents  Int
  createdAt   DateTime @default(now())
}

// 4.1 — Referral program
model ReferralCode {
  id          String     @id @default(cuid())
  code        String     @unique  // e.g. "MARCUS20"
  user        User       @relation(fields: [userId], references: [id])
  userId      String     @unique  // one code per user
  referrals   Referral[]
  createdAt   DateTime   @default(now())
}

model Referral {
  id            String       @id @default(cuid())
  code          ReferralCode @relation(fields: [codeId], references: [id])
  codeId        String
  referrerId    String       // user who owns the code
  refereeId     String       // user who signed up using the code
  refereeEmail  String
  status        String       @default("pending")
  // pending → qualified (referee places first order) → credited (credit issued)
  creditIssuedAt DateTime?
  createdAt     DateTime     @default(now())

  @@unique([codeId, refereeId])
}

model StoreCredit {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  amountCents Int      // credit amount
  reason      String   // "Referral: Marcus Chen", "Goodwill", etc.
  usedAt      DateTime?
  orderId     String?  // which order it was applied to
  createdAt   DateTime @default(now())
}

// 4.2 — Onboarding
model OnboardingProgress {
  id                    String   @id @default(cuid())
  user                  User     @relation(fields: [userId], references: [id])
  userId                String   @unique
  addressAdded          Boolean  @default(false)
  equipmentDeclared     Boolean  @default(false)
  firstPackagingBrowse  Boolean  @default(false)
  firstOrder            Boolean  @default(false)
  profileComplete       Boolean  @default(false)
  completedAt           DateTime?
  createdAt             DateTime @default(now())
}

// 5.1 — Notifications
model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      String   // "order_status" | "balance_due" | "service_ticket" | "referral_credit" | "review_request"
  title     String
  body      String
  href      String?  // where to go when clicked
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// 5.2 — Activity feed entries (separate from notifications — these are permanent records)
model ActivityEntry {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      String   // "order_placed" | "order_shipped" | "deposit_paid" | "balance_paid" | "sub_renewed" | "review_left"
  title     String
  metadata  Json?    // { orderId, productName, amount, etc. }
  createdAt DateTime @default(now())
}

// 5.3 — Blog
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   // markdown
  coverUrl    String?
  category    String   // "guide" | "news" | "comparison"
  tags        String[]
  published   Boolean  @default(false)
  publishedAt DateTime?
  readingMins Int      @default(5)
  authorName  String   @default("Roast & Recover")
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}