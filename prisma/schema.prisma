// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// schema.prisma

model User {
  id String @id @default(cuid())

  clerkId String @unique

  email String @unique
  name String?

  role Role @default(CUSTOMER)

  company Company? @relation(fields: [companyId], references: [id])
  companyId String?

  addresses Address[]

  orders Order[]
   reviews   Review[]
  subscriptions Subscription[]
  equipmentItems EquipmentRegistryItem[]

  createdAt DateTime @default(now())
}
enum Role {
  CUSTOMER
  ADMIN
}

model Company {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  addresses Address[]
  createdAt DateTime @default(now())
}

model Address {
  id        String   @id @default(cuid())

  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  orders    Order[]  // 👈 ADD THIS (inverse relation)

  line1     String
  line2     String?
  city      String
  state     String
  zip       String
  country   String   @default("US")
}

model Product {
  id              String        @id @default(cuid())
  category        ProductCategory
  name            String
  slug            String        @unique
  description     String
  priceCents      Int
  depositPercent  Int?
  leadTimeDays    Int?
  reviews   Review[]

  certification   Certification? @relation(fields: [certificationId], references: [id])
  certificationId String?

  isSubscribable  Boolean @default(false)
  active          Boolean @default(true)
  images          String[]
  stripePriceId   String?   // Stripe recurring Price ID — subscriptions only
  createdAt       DateTime @default(now())

  // 👇 ADD THESE INVERSE RELATIONS
  orderItems      OrderItem[]
  subscriptions   Subscription[]
  equipmentItems  EquipmentRegistryItem[]
  productionBatches ProductionBatch[]
}



enum ProductCategory {
  EQUIPMENT
  PACKAGING
}

model Certification {
  id            String   @id @default(cuid())
  type          String
  listingNumber String
  documentUrl   String
  verifiedAt    DateTime?
  expiresAt     DateTime?

  createdAt     DateTime @default(now())

  products      Product[]
}

model Order {
  id              String       @id @default(cuid())
  user            User         @relation(fields: [userId], references: [id])
  userId          String

  status          OrderStatus  @default(PENDING_DEPOSIT)

  items           OrderItem[]

  depositPaidAt   DateTime?
  balancePaidAt   DateTime?

  stripeDepositPaymentIntentId String?
  stripeBalancePaymentIntentId String?

  shippingAddress Address? @relation(fields: [addressId], references: [id])
  addressId       String?

  estimatedShipDate DateTime?
  shippedAt       DateTime?

  createdAt       DateTime @default(now())

  // 👇 ADD THIS
  equipmentRegistryItems EquipmentRegistryItem[]
}

enum OrderStatus {
  PENDING
  PENDING_DEPOSIT     // equipment: waiting on deposit payment
  AWAITING_BALANCE    // equipment: deposit paid, sourcing/building, balance not yet due
  PAID                // packaging: paid in full, or equipment: balance paid
  IN_PRODUCTION        // equipment: factory order placed
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  PENDING_DEPOSIT
  AWAITING_BALANCE
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id          String   @id @default(cuid())

  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String

  product     Product  @relation(fields: [productId], references: [id])
  productId   String

  quantity       Int
  unitPriceCents Int

  // Equipment-specific per-item tracking
  // Packaging orders leave these null
  depositPercent Int?
  itemStatus     OrderItemStatus @default(PENDING_DEPOSIT)
  depositPaidAt  DateTime?
  balancePaidAt  DateTime?
  stripeDepositPaymentIntentId String?
  stripeBalancePaymentIntentId String?
  estimatedShipDate            DateTime?
  shippedAt                    DateTime?
}

model Subscription {
  id                    String   @id @default(cuid())

  user                  User     @relation(fields: [userId], references: [id])
  userId                String

  product               Product  @relation(fields: [productId], references: [id])
  productId             String

  stripeSubscriptionId  String   @unique
  status                String
  intervalDays          Int

  createdAt             DateTime @default(now())
}

model EquipmentRegistryItem {
  id            String   @id @default(cuid())

  user          User     @relation(fields: [userId], references: [id])
  userId        String

  product       Product  @relation(fields: [productId], references: [id])
  productId     String

  order         Order?   @relation(fields: [orderId], references: [id])
  orderId       String?
  

  installedAt   DateTime?
  warrantyEndsAt DateTime?
}

model ProductionBatch {
  id          String   @id @default(cuid())
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  quantity    Int
  status      String
  eta         DateTime?
  createdAt   DateTime @default(now())  // ← add this
}

model Review {
  id        String   @id @default(cuid())

  product   Product  @relation(fields: [productId], references: [id])
  productId String

  user      User     @relation(fields: [userId], references: [id])
  userId    String

  rating    Int      // 1–5
  title     String?
  body      String

  // Only customers who actually ordered can review
  verified  Boolean  @default(false)

  createdAt DateTime @default(now())

  @@unique([productId, userId]) // one review per product per user
}


enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  CONVERTED
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  message   String
  interest  String?    // "equipment" | "packaging" | "both" | "custom"
  productId String?    // if from a specific product page quote button
  status    LeadStatus @default(NEW)
  notes     String?    // admin internal notes
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String
  company     String
  location    String?
  quote       String
  logoUrl     String?
  avatarUrl   String?
  rating      Int      @default(5)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}